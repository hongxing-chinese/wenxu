# ============================================================
# 问虚 - 环境变量配置示例
# 复制本文件为 .env 并填入实际值
# ============================================================

# ---------- Edge KV 命名空间 ----------
# 在 ESA 控制台创建 KV 命名空间后填入名称
KV_NAMESPACE=wenxu-kv

# ---------- 应用域名 ----------
# 生产环境填你的正式域名
APP_ORIGIN=https://wenxu.example.com

# ---------- LLM 代理配置（云端模式） ----------
# 云端代理调用的大模型 API（兼容 OpenAI 格式）
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
LLM_API_KEY=