{
  "name": "wenxu",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "node --env-file=.env --import tsx proxy/dev-server.mjs",
    "dev:full": "concurrently \"npm run dev:api\" \"npm run dev\"",
    "build": "vite build",
    "build:proxy": "node proxy/build.mjs",
    "build:all": "npm run build && npm run build:proxy",
    "preview": "vite preview",
    "test": "tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "iztro": "^2.5.8",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.9.4",
    "remark-gfm": "^4.0.1",
    "tyme4ts": "^1.3.3"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.7"
  }
}
